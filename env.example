# Railway / Server
NODE_ENV=production
PORT=3000

# PostgreSQL - su Railway metti nel servizio backend:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# oppure copia direttamente la DATABASE_URL dal database Railway
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Anthropic - tienila SOLO nel backend, mai nel frontend
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Auth
JWT_SECRET=change-this-with-a-long-random-secret-64-chars-minimum
JWT_EXPIRES_IN=30d

# CORS - domini frontend separati da virgola
# Esempio: https://tuodominio.it,https://www.tuodominio.it,http://localhost:5173
CORS_ORIGIN=https://tuodominio.it,https://www.tuodominio.it,http://localhost:5173,http://localhost:3000

# Crediti
DEFAULT_FREE_CREDITS=20
CHAT_CREDIT_COST=1
